# ─── REQUIRED ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...          # Stripe dashboard → Developers → API keys
NOTION_API_KEY=secret_...             # notion.so/my-integrations → New integration
NOTION_PARENT_PAGE_ID=...             # The Notion page ID where the DB will be created
                                       # (open the page in Notion, copy the 32-char ID from the URL)

# ─── OPTIONAL — Tally (beta API) ─────────────────────────────────
TALLY_API_KEY=...                      # tally.so/settings → API (beta)

# ─── YOUR DETAILS ─────────────────────────────────────────────────
SITE_URL=https://aegeanai.vercel.app   # Your live Vercel URL (no trailing slash)
FOUNDER_NAME=Your Name
SUPPORT_EMAIL=hello@aegeanai.com
